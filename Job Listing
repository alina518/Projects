if __name__ == "__main__":
    validate_config()

    print("\n===== USER PROFILE =====")
    name = input("Enter your name: ").strip()
    email = input("Enter your email: ").strip()
    phone = input("Enter your phone: ").strip()
    linkedin = input("Enter your LinkedIn profile: ").strip()
    experience = input("Enter your experience level (e.g. Fresher): ").strip()
    target_role = input("Enter your target role: ").strip()

    skills_input = input("Enter your skills separated by commas: ").strip()
    skills = [skill.strip() for skill in skills_input.split(",") if skill.strip()]

    projects_input = input("Enter your projects separated by commas: ").strip()
    projects = [project.strip() for project in projects_input.split(",") if project.strip()]

    user_profile = {
        "name": name,
        "email": email,
        "phone": phone,
        "linkedin": linkedin,
        "experience": experience,
        "target_role": target_role,
        "skills": skills,
        "projects": projects
    }

    print("\n===== JOB FILTERS =====")
    keyword = input("Enter keyword (default: Python): ").strip()
    location = input("Enter location (default: Bengaluru): ").strip()

    salary_input = input("Enter minimum salary (or leave blank): ").strip()
    min_salary = int(salary_input) if salary_input else None

    preferred_work_mode = input(
        "Preferred work mode [remote/hybrid/onsite] (or leave blank): "
    ).strip().lower()
    if preferred_work_mode not in ["remote", "hybrid", "onsite"]:
        preferred_work_mode = None

    company_name = input("Enter company name filter (or leave blank): ").strip()
    if not company_name:
        company_name = None

    preferred_job_type = input(
        "Preferred job type [full-time/internship] (or leave blank): "
    ).strip().lower()
    if preferred_job_type not in ["full-time", "internship"]:
        preferred_job_type = None

    found_jobs = fetch_jobs(
        keyword=keyword if keyword else "Python",
        location=location if location else "Bengaluru",
        min_salary=min_salary,
        preferred_work_mode=preferred_work_mode,
        company_name=company_name,
        preferred_job_type=preferred_job_type,
        user_skills=user_profile["skills"]
    )

    if not found_jobs:
        print("No new matching jobs found.")
    else:
        print("\nTop jobs:")
        for i, job in enumerate(found_jobs[:3], start=1):
            print(f"{i}. {job['title']} at {job['company']} | Match Score: {job['match_score']}%")

        # Save CSV always
        save_jobs_to_csv(found_jobs)

        # Generate outreach files for top 3
        for job in found_jobs[:3]:
            cover_letter = generate_cover_letter(user_profile, job)
            hr_email = generate_hr_email(user_profile, job)
            linkedin_msg = generate_linkedin_message(user_profile, job)

            save_outreach_files(job, cover_letter, hr_email, linkedin_msg)

        # Send WhatsApp first
        sent = send_whatsapp(found_jobs, user_profile)

        # Only mark as seen if message sent successfully
        if sent:
            seen_jobs = load_seen_jobs()
            for job in found_jobs:
                seen_jobs.add(job["job_id"])
            save_seen_jobs(seen_jobs)
            print("✅ Seen jobs updated.")

        print(f"✅ Outreach drafts saved in folder: {OUTREACH_FOLDER}")
        print(f"✅ Job history saved in file: {CSV_FILE}")
